# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Home Assistant connection
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# Calendar entity ID in Home Assistant (e.g., calendar.work_schedule)
HA_CALENDAR_ENTITY=calendar.schedule

# Comma-separated list of allowed Telegram chat IDs (leave empty to allow all)
ALLOWED_CHAT_IDS=

# Timezone (used for calendar event creation)
TZ=America/New_York

# Optional: enable AI vision parsing before OCR fallback
AI_PARSER_ENABLED=true

# OpenAI-compatible API endpoint (default: official OpenAI)
# For LM Studio on localhost: http://localhost:1234/v1
# For remote LM Studio: http://<host>:1234/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# API key (can be any string for local servers like LM Studio)
OPENAI_API_KEY=

# Model name available at the endpoint
# See docs/MODEL_RECOMMENDATIONS.md for open-weight vision models
OPENAI_MODEL=gpt-4o-mini

# Timeout in seconds for AI model loading + inference (default: 60)
# Increase for local models that need time to load into VRAM (e.g., 120 or 180)
AI_TIMEOUT=60
